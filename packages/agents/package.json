{
  "name": "@qyro/agents",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./runner": {
      "types": "./src/runner.ts",
      "require": "./dist/runner.js",
      "default": "./dist/runner.js"
    },
    "./budget": {
      "types": "./src/budget.ts",
      "require": "./dist/budget.js",
      "default": "./dist/budget.js"
    },
    "./leadDiscovery": {
      "types": "./src/agents/leadDiscovery.ts",
      "require": "./dist/agents/leadDiscovery.js",
      "default": "./dist/agents/leadDiscovery.js"
    },
    "./clientAssistant": {
      "types": "./src/agents/clientAssistant.ts",
      "require": "./dist/agents/clientAssistant.js",
      "default": "./dist/agents/clientAssistant.js"
    },
    "./voiceAssistant": {
      "types": "./src/agents/voiceAssistant.ts",
      "require": "./dist/agents/voiceAssistant.js",
      "default": "./dist/agents/voiceAssistant.js"
    },
    "./assistBooking": {
      "types": "./src/assistBooking.ts",
      "require": "./dist/assistBooking.js",
      "default": "./dist/assistBooking.js"
    },
    "./bookingService": {
      "types": "./src/bookingService.ts",
      "require": "./dist/bookingService.js",
      "default": "./dist/bookingService.js"
    },
    "./compact": {
      "types": "./src/compact.ts",
      "require": "./dist/compact.js",
      "default": "./dist/compact.js"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@qyro/db": "workspace:*",
    "@qyro/queue": "workspace:*",
    "openai": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0"
  }
}
