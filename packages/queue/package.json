{
  "name": "@qyro/queue",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "worker:research": "tsx src/workers/researchWorker.ts",
    "worker:outreach": "tsx src/workers/outreachWorker.ts",
    "worker:outbound-call": "tsx src/workers/outboundCallWorker.ts",
    "worker:webhook": "tsx src/workers/webhookWorker.ts",
    "worker:reply-triage": "tsx src/workers/replyTriageWorker.ts",
    "worker:anomaly-detection": "tsx src/workers/anomalyDetectionWorker.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./queues": {
      "types": "./src/queues.ts",
      "require": "./dist/queues.js",
      "default": "./dist/queues.js"
    }
  },
  "dependencies": {
    "@qyro/db": "workspace:*",
    "bullmq": "^5.0.0",
    "ioredis": "^5.3.0",
    "luxon": "^3.7.2",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
