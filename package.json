{
  "name": "qyro",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "smoke:workers": "pnpm --filter @qyro/workers run smoke:typecheck",
    "test:tenant-middleware": "pnpm --filter @qyro/api run test:tenant-middleware",
    "clean:mac-junk": "find . -name \"._*\" -type f -delete && find . -name \".DS_Store\" -type f -delete",
    "clean:artifacts": "find apps packages -path '*/dist/*' -prune -exec rm -rf {} + && find packages/agents/src -type f \\( -name '*.js' -o -name '*.d.ts' -o -name '*.map' \\) -delete",
    "db:generate": "pnpm --filter @qyro/db generate",
    "db:migrate": "pnpm --filter @qyro/db migrate",
    "db:studio": "pnpm --filter @qyro/db studio",
    "backfill:tenant-secrets": "tsx scripts/backfill-tenant-secrets.ts",
    "backfill:prospect-timezones": "tsx scripts/backfill-prospect-timezones.ts",
    "migrate": "tsx infra/migrate.ts",
    "test:e2e": "tsx scripts/test-e2e.ts",
    "worker:reply-triage": "pnpm --filter @qyro/workers run worker:reply-triage",
    "worker:outreach": "pnpm --filter @qyro/workers run worker:outreach",
    "worker:research": "pnpm --filter @qyro/workers run worker:research"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.30.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0"
  }
}
