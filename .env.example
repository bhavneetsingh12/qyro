# Copy this to .env.local and fill in your values
# NEVER commit .env.local

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://qyro:qyro@localhost:5432/qyro
DATABASE_URL_TEST=postgresql://qyro:qyro@localhost:5433/qyro_test

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Clerk Auth ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── Stripe Billing ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
APP_BASE_URL=http://localhost:3000
STRIPE_PRICE_LEAD_STARTER=price_...
STRIPE_PRICE_LEAD_GROWTH=price_...
STRIPE_PRICE_ASSIST_STARTER=price_...
STRIPE_PRICE_ASSIST_GROWTH=price_...
STRIPE_PRICE_BUNDLE_STARTER=price_...
STRIPE_PRICE_BUNDLE_GROWTH=price_...

# ─── Seed (fill in your actual Clerk user ID from Clerk dashboard) ────────────
SEED_CLERK_USER_ID=user_...

# ─── Apollo (lead sourcing) ───────────────────────────────────────────────────
APOLLO_API_KEY=

# ─── Google Places ────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=

# ─── Email enrichment (optional) ─────────────────────────────────────────────
# Set provider to 'mock' for cheap local simulation.
EMAIL_ENRICHER_PROVIDER=mock
EMAIL_ENRICHER_API_KEY=

# ─── API server ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Web local development flags ─────────────────────────────────────────────
# Set true only for local debugging when you need to view internal pages without Clerk sign-in.
DEV_BYPASS_AUTH=false

# ─── Twilio ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC_REPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_PHONE_NUMBER=+1REPLACE_ME
PUBLIC_API_BASE_URL=http://localhost:3001

# ─── Voice / Outbound ─────────────────────────────────────────────
OUTBOUND_VOICE_GLOBAL_PAUSED=false
DEFAULT_TIMEZONE=America/Los_Angeles

# ─── Retell Voice Runtime ──────────────────────────────────────────
RETELL_API_KEY=REPLACE_ME
RETELL_AGENT_ID_DEFAULT=agent_REPLACE_ME
RETELL_WEBHOOK_SECRET=REPLACE_ME
RETELL_BASE_URL=https://api.retellai.com
# Optional override if provider path changes
RETELL_CREATE_CALL_PATH=/v2/create-phone-call

# ─── Calendar ─────────────────────────────────────────────────────
DEFAULT_CALENDAR_PROVIDER=cal_com
GOOGLE_CALENDAR_ID=REPLACE_ME
CAL_API_KEY=REPLACE_ME
CAL_EVENT_TYPE_ID=REPLACE_ME

# ─── Internal ─────────────────────────────────────────────────────
INTERNAL_TENANT_ID=REPLACE_ME
EXTRA_WEB_ORIGIN=http://localhost:3000
PROMPTS_DIR=docs/PROMPTS

# ─── Internal automation webhooks (Railway cron -> API) ─────────────────────
WEBHOOK_SECRET=change-me

# ─── SignalWire (voice transport — replaces Twilio wiring) ────────────────────
SIGNALWIRE_PROJECT_ID=REPLACE_ME
SIGNALWIRE_API_TOKEN=REPLACE_ME
SIGNALWIRE_SPACE_URL=REPLACE_ME.signalwire.com

# ─── Master admin access ──────────────────────────────────────────────────────
# Comma-separated Clerk user IDs and/or emails granted master_admin access.
# These can override the DB role. Leave blank to rely on DB role only.
MASTER_ADMIN_CLERK_IDS=
MASTER_ADMIN_EMAILS=

# ─── Web / API cross-origin config ────────────────────────────────────────────
# Web app URL (used for CORS on API server and Stripe return URLs)
WEB_ORIGIN=http://localhost:3000
# URL used by Next.js layouts to call the API server (server-side fetch)
API_URL=http://localhost:3001
