{
  "name": "@qyro/queue",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "worker:research": "tsx --env-file-if-exists=../../.env.local src/workers/researchWorker.ts",
    "worker:outreach": "tsx --env-file-if-exists=../../.env.local src/workers/outreachWorker.ts",
    "worker:outbound-call": "tsx --env-file-if-exists=../../.env.local src/workers/outboundCallWorker.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./queues": {
      "types": "./src/queues.ts",
      "require": "./dist/queues.js",
      "default": "./dist/queues.js"
    }
  },
  "dependencies": {
    "@qyro/db": "workspace:*",
    "bullmq": "^5.0.0",
    "ioredis": "^5.3.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
